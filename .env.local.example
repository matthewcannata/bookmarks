# Image-generation provider keys — fill in whichever you want to use.
# The UI lets you switch between providers at runtime.

# OpenAI (gpt-image-1) — strong at typography / quote bookmarks
OPENAI_API_KEY=

# Replicate — multi-model gateway (Ideogram = best text, Flux = best art)
REPLICATE_API_TOKEN=

# Stability AI — cheapest, good for illustrations
STABILITY_API_KEY=
